# AdaptaAI — env template. Copy to infra/.env and fill in real values.
# infra/.env is gitignored — never commit secrets.

# --- GigaChat (Sber, authorize via ЛК → Authorization key) -----------------
GIGACHAT_AUTHORIZATION_KEY=<base64-string-from-sber-cabinet>
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2-Pro
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_CA_BUNDLE_PATH=/app/certs/russian_trusted_root_ca.pem

# --- Qwen via OpenRouter (https://openrouter.ai/keys) ----------------------
OPENROUTER_API_KEY=sk-or-v1-<token>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
QWEN_MODEL=qwen/qwen-2.5-72b-instruct

# --- Postgres (docker-compose) ---------------------------------------------
POSTGRES_DB=adapta
POSTGRES_USER=adapta
POSTGRES_PASSWORD=change-me-strong-string
DATABASE_URL=postgresql+asyncpg://adapta:change-me-strong-string@postgres:5432/adapta

# --- JWT / Invite secrets (generate via `openssl rand -hex 32`) ------------
JWT_SECRET=<random-32-byte-hex-string>
JWT_ALGORITHM=HS256
JWT_TTL_HR_SECONDS=28800        # 8h
JWT_TTL_MIGRANT_SECONDS=2592000 # 30d
INVITE_SECRET=<random-32-byte-hex>
INVITE_TTL_HOURS=168            # 7 days

# --- Demo mode (optional) --------------------------------------------------
ADAPTA_DEMO_ENABLED=false
ADAPTA_DEMO_PASSWORD=<set-a-strong-password>

# --- Embeddings / Chroma (Phase 2) -----------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-base
CHROMA_PERSIST_PATH=/app/data/chroma

# --- RAG eval judge (RAGAS) ------------------------------------------------
RAGAS_JUDGE_MODEL=google/gemini-2.5-flash

# --- SMTP (real email — uncomment to override MailHog) ---------------------
# Default flow uses MailHog (smtp_host=mailhog:1025, no auth, no TLS).
# To send real emails (e.g. for demo recording), uncomment and fill in:
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USERNAME=your-login@yandex.ru
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_SECURITY=tls
# SMTP_FROM=your-login@yandex.ru
# INVITE_BASE_URL=https://your-tunnel.ngrok-free.app/i
